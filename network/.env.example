INKBOX_API_KEY=your_inkbox_api_key_here
# Webhook + tunnel gateway (python run_inkbox_gateway.py) — from console.inkbox.ai/webhooks
INKBOX_SIGNING_KEY=whsec_your_signing_key_here
# Unique subdomain for Inkbox tunnel, e.g. my-connet-dev
INKBOX_TUNNEL_NAME=
OPENAI_API_KEY=your_openai_api_key_here
INKBOX_API_KEY_2=your_second_agent_api_key_here
MY_EMAIL=your_email@example.com
MY_PHONE=+1234567890
VAULT_KEY=YourVaultKey-2026!
AGENT_NAME=your-agent-handle
AGENT2_NAME=your-second-agent-handle

# Optional: set true when using run_inkbox_gateway.py (defaults to true in that entrypoint)
# CONNET_WEBHOOK_INTEGRATION=true

# Inkbox org Contacts + Notes (requires inkbox>=0.3.2). Set CONNET_ORG_CONTEXT=false to skip API calls.
# CONNET_ORG_CONTEXT=true
# CONNET_AUTO_NOTE_HOT_INBOUND=false
